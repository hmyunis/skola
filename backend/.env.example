# SERVER
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# DATABASE (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=skola_db

# TELEGRAM AUTH
TELEGRAM_BOT_TOKEN=your_bot_token_here

# SECURITY
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# JWT AUTH
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRATION=7d

# LOUNGE IMAGE UPLOAD (optional if users use personal BYOK keys)
IMGBB_API_KEY=your_imgbb_api_key_here

# ENCRYPTION FOR USER-SAVED PERSONAL IMAGE KEYS (recommended)
# If empty, JWT_SECRET is used as fallback. Set explicitly in production.
BYOK_ENCRYPTION_KEY=your_32_plus_char_random_secret_here

# WEB PUSH NOTIFICATIONS (VAPID)
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:you@example.com
